# Copy this into Streamlit Community Cloud → App → Settings → Secrets
# (do NOT commit the real secrets.toml — it is gitignored).
#
# These let the externally-hosted app authenticate to Databricks as the
# `auction-external-host` service principal and reach Lakebase.

# Uses the app's own service principal, which OWNS the auction tables — so no
# extra Postgres grants are needed.
DATABRICKS_HOST = "https://dbc-e6b4414f-de4d.cloud.databricks.com"
DATABRICKS_CLIENT_ID = "2ab33e8b-1d87-496e-b9c8-466216a52761"
DATABRICKS_CLIENT_SECRET = "REPLACE_WITH_SP_OAUTH_SECRET"

LAKEBASE_INSTANCE_NAME = "auction-lakebase"
PGHOST = "ep-misty-sea-d8vcrv98.database.us-east-2.cloud.databricks.com"
PGUSER = "2ab33e8b-1d87-496e-b9c8-466216a52761"

# Organizer passcode — anyone who enters this in the app gets the Admin tab
# (upload Excel, activate batches). Change it to something only you know.
ADMIN_PASSCODE = "change-me-to-a-secret"
